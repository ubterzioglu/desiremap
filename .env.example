# Server-side upstream for Next BFF routes.
# Future-safe examples:
# BACKEND_API_URL="https://api.desiremap.de/v1"
# BACKEND_API_URL="https://api.desiremap.de/v2"
BACKEND_API_URL="https://api.desiremap.de/api"

# Browser-facing base for legacy direct calls not moved behind BFF yet.
NEXT_PUBLIC_API_URL="https://api.desiremap.de/api"

# Same-origin Next BFF base for public/discovery routes.
NEXT_PUBLIC_APP_API_URL="/api"

# Internal token for Next.js → backend page-view tracking (must match backend INTERNAL_TRACKING_TOKEN)
INTERNAL_TRACKING_TOKEN=""

# Google Identity Services web client IDs (comma-separated allowed; frontend uses the first entry at runtime).
MEMBER_AUTH_GOOGLE_CLIENT_IDS=""

# Optional single-value override if frontend and backend env names differ.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
