// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ====================
// ENUMS
// ====================

enum UserRole {
  CUSTOMER
  OWNER
  ADMIN
}

enum BordellType {
  LAUFHAUS
  BORDELL
  FKK
  STUDIO
  PRIVAT
}

enum BordellStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PremiumPlan {
  BASIC
  PREMIUM
  SPONSORED
}

// ====================
// MODELS
// ====================

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  password      String?     // Optional for OAuth users
  googleId      String?     @unique // Google OAuth ID
  name          String?
  phone         String?
  avatar        String?
  role          UserRole    @default(CUSTOMER)
  status        CustomerStatus @default(ACTIVE)
  emailVerified DateTime?   // null = not verified
  memberSince   DateTime    @default(now())
  lastLogin     DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  addresses     Address[]
  visits        Visit[]
  badges        UserBadge[]
  bookingsAsCustomer Booking[]  @relation("CustomerBookings")
  ownedBordells Bordell[]     @relation("OwnerBordells")
  reviews       Review[]
  invoices      Invoice[]

  @@map("users")
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String
  street      String
  city        String
  zip         String
  country     String   @default("Deutschland")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Visit {
  id          String   @id @default(cuid())
  userId      String
  bordellId   String
  date        DateTime
  duration    Int      // minutes
  price       Float
  rating      Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bordell     Bordell  @relation(fields: [bordellId], references: [id], onDelete: Cascade)

  @@map("visits")
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String
  color       String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeId     String
  earnedAt    DateTime @default(now())

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge       Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Bordell {
  id              String        @id @default(cuid())
  name            String
  type            BordellType   @default(BORDELL)
  location        String
  city            String
  distance        String?
  rating          Float         @default(0)
  reviewCount     Int           @default(0)
  priceRange      String?
  minPrice        Float?
  maxPrice        Float?
  ladiesCount     Int           @default(0)
  services        String?       // JSON array as string
  isOpen          Boolean       @default(true)
  openHours       String?
  verified        Boolean       @default(false)
  premium         Boolean       @default(false)
  premiumExpiry   DateTime?
  premiumPlan     PremiumPlan?
  sponsored       Boolean       @default(false)
  sponsoredExpiry DateTime?
  phone           String?
  email           String?
  website         String?
  description     String?
  coverImage      String?
  images          String?       // JSON array as string
  availableSlots  String?       // JSON array as string
  status          BordellStatus @default(PENDING)
  views           Int           @default(0)
  bookings        Int           @default(0)
  revenue         Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  ownerId         String?
  owner           User?         @relation("OwnerBordells", fields: [ownerId], references: [id], onDelete: SetNull)
  bordellVisits   Visit[]
  bordellBookings Booking[]
  bordellReviews  Review[]

  @@map("bordells")
}

model Booking {
  id              String        @id @default(cuid())
  customerId      String
  bordellId       String
  date            DateTime
  time            String
  duration        Int           // minutes
  price           Float
  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  notes           String?
  rating          Int?
  review          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  customer        User          @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  bordell         Bordell       @relation(fields: [bordellId], references: [id], onDelete: Cascade)
  invoice         Invoice?

  @@map("bookings")
}

model Review {
  id          String       @id @default(cuid())
  customerId  String
  bordellId   String
  rating      Int
  title       String
  content     String
  status      ReviewStatus @default(PENDING)
  response    String?
  respondedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  customer    User         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bordell     Bordell      @relation(fields: [bordellId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Invoice {
  id          String        @id @default(cuid())
  bookingId   String        @unique
  userId      String
  amount      Float
  status      PaymentStatus @default(PENDING)
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("invoices")
}
